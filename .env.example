# ============================================================
# Rota 12 — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA comite o arquivo .env no repositório!
# ============================================================

# --- Aplicação ---
# URL completa do site, incluindo o subdiretório (sem barra final)
APP_URL=https://www.rota12.com/versao2
APP_ENV=production

# --- Banco de Dados ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nome_do_banco
DB_USER=usuario_do_banco
DB_PASS=senha_do_banco
DB_CHARSET=utf8mb4
