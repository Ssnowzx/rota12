# ============================================================
# FILE: public/.htaccess
# PURPOSE: Frontend rewrite rules, security headers, access control
# SERVER: Apache 2.4 / cPanel / Linux
# ============================================================

# --- Directory Listing ---
Options -Indexes

# --- Rewrite Engine ---
RewriteEngine On
RewriteBase /

# --- Block access to hidden files (.env, .git, etc.) ---
RewriteRule (^|/)\.(?!well-known) - [F,L]

# --- Do NOT rewrite existing files or directories ---
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# --- Do NOT rewrite /uploads/ or /assets/ directories ---
RewriteRule ^uploads/ - [L]
RewriteRule ^assets/ - [L]

# --- Route everything else to index.php ---
RewriteRule ^(.*)$ index.php [QSA,L]

# --- PHP Upload Configuration ---
<IfModule mod_php.c>
    php_value upload_max_filesize 3M
    php_value post_max_size 5M
    php_value max_input_vars 5000
</IfModule>

# --- Security Headers ---
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "same-origin"
</IfModule>

# --- Block .env, .git, and other sensitive hidden files ---
<FilesMatch "(^\.env|^\.git|\.htpasswd|\.htaccess)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# --- Block PHP execution inside /uploads/ ---
<DirectoryMatch "uploads">
    <FilesMatch "\.php$">
        <IfModule mod_authz_core.c>
            Require all denied
        </IfModule>
        <IfModule !mod_authz_core.c>
            Order deny,allow
            Deny from all
        </IfModule>
    </FilesMatch>
    <IfModule mod_php.c>
        php_flag engine off
    </IfModule>
    <IfModule mod_php7.c>
        php_flag engine off
    </IfModule>
    <IfModule mod_php8.c>
        php_flag engine off
    </IfModule>
    RemoveHandler .php .php3 .php4 .php5 .php7 .phtml .phar
</DirectoryMatch>
